# --- Telegram sozlamalari / Telegram settings ---
# Bu qiymatlarni Vercel'da ham qo'shing:
#   Vercel → Project → Settings → Environment Variables

# @BotFather dan olingan bot token
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Arizalar yuboriladigan chat/guruh/kanal ID
# O'z ID'ingizni bilish uchun: botga yozing va @userinfobot dan foydalaning
TELEGRAM_CHAT_ID=123456789

# Server porti (ixtiyoriy, faqat lokal server.js uchun)
PORT=3000
